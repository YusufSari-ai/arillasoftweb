// Arillasoft - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum ProjectType {
  WEB_APPLICATION
  MOBILE_APPLICATION
  CUSTOM_SOFTWARE
  UI_UX_DESIGN
  BACKEND_API
  ECOMMERCE
  SAAS
  OTHER
}

enum BudgetRange {
  UNDER_10K
  RANGE_10K_25K
  RANGE_25K_50K
  RANGE_50K_100K
  ABOVE_100K
  UNDECIDED
}

enum TargetPlatform {
  WEB
  IOS
  ANDROID
  BOTH_MOBILE
  DESKTOP
  ALL_PLATFORMS
}

// ==================== ADMIN ====================

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ==================== SERVICES ====================

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  content          String   @db.Text
  icon             String
  isFeatured       Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==================== SOLUTIONS ====================

model Solution {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  content          String   @db.Text
  icon             String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==================== PROJECTS ====================

model ProjectCategory {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  projects Project[]
}

model Project {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  summary       String
  content       String          @db.Text
  coverImage    String?
  gallery       String[]
  clientName    String?
  sector        String?
  technologies  String[]
  resultMetrics String?
  isFeatured    Boolean         @default(false)
  published     Boolean         @default(false)
  categoryId    String?
  category      ProjectCategory? @relation(fields: [categoryId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ==================== BLOG ====================

model BlogCategory {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  posts BlogPost[]
}

model BlogPost {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  excerpt        String
  content        String       @db.Text
  coverImage     String?
  readingTime    Int          @default(5)
  published      Boolean      @default(false)
  featured       Boolean      @default(false)
  categoryId     String?
  category       BlogCategory? @relation(fields: [categoryId], references: [id])
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ==================== FAQ ====================

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String   @default("Genel")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== TEAM ====================

model TeamMember {
  id          String   @id @default(cuid())
  fullName    String
  title       String
  bio         String?  @db.Text
  avatar      String?
  linkedinUrl String?
  githubUrl   String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TESTIMONIALS ====================

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String
  title     String
  quote     String   @db.Text
  avatar    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== CONTACT / QUOTE ====================

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id                  String         @id @default(cuid())
  fullName            String
  email               String
  phone               String?
  company             String?
  projectType         ProjectType
  budgetRange         BudgetRange
  targetPlatform      TargetPlatform
  deliveryExpectation String?
  description         String         @db.Text
  integrations        String?
  hasExistingSystem   Boolean        @default(false)
  isRead              Boolean        @default(false)
  createdAt           DateTime       @default(now())
}

// ==================== SITE SETTINGS ====================

model SiteSetting {
  id              String   @id @default(cuid())
  siteName        String   @default("Arillasoft")
  siteDescription String?
  contactEmail    String?
  contactPhone    String?
  address         String?
  linkedinUrl     String?
  githubUrl       String?
  instagramUrl    String?
  twitterUrl      String?
  logoPath        String?
  faviconPath     String?
  updatedAt       DateTime @updatedAt
}

// ==================== PARTNERS / CLIENTS ====================

model PartnerLogo {
  id         String   @id @default(cuid())
  name       String
  imagePath  String
  websiteUrl String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
